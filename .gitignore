# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Generated protobuf/tonic files
**/src/generated/
**/*.pb.rs

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Windows NUL device accidentally created as a file (usually from `2>nul` under bash)
nul

# Property-based test failure logs (generated by quickcheck)
crates/engine/property_test_failures.log

# Proptest regression files (auto-generated by proptest on failure)
**/*.proptest-regressions

build_output*.log
check_*.py
fix_*.py
debug_*.py
setup_*.py
_addtests.py

# Temporary files and scripts
run_steps.ps1
test_output.txt
test_*.txt
test_*.json
tmp_*.txt
*_out.txt
*_output.txt
scratch.rs

# Debug/analysis output dumps
allocation_debug*.txt
clippy_*.txt
doc_*.txt
engine_test*.txt
metadata_error*.txt
missing_docs*.txt
*_failure.txt
unique_crates.txt
workspace_tests*.txt

# Support bundle archives from CLI testing
crates/cli/support_bundle_*.zip

# Temporary test/compat output
compat_current.json
compat_usage_report.json

# Machine-specific cargo state; .cargo/config.toml is committed for workspace aliases.
.cargo/*
!.cargo/config.toml

# Python bytecode
__pycache__/
*.pyc

# Temporary debugging/analysis files at repo root
check_errors*.txt
check_output*.txt
check_output*.json
error_check.txt
fatal*.txt
final_test_results.txt
test_output.log
all_diff.txt
my_diff.txt
diff_*.txt
prs.json
status.txt
*_err.log
err.log
log.txt
int_err.log
svc_err.log
doc_err.log

# Bench results (generated, not source)
crates/engine/bench_results.json
