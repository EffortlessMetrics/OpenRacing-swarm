{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.local/schemas/hardware/sniffing/sniff-receipt.schema.json",
  "title": "OpenRacing Passive USB Sniff Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "success",
    "command",
    "generated_at_utc",
    "plan_path",
    "pcapng_path",
    "pcapng_sha256",
    "pcapng_size_bytes",
    "operator",
    "app",
    "scenario",
    "device_note",
    "evidence",
    "evidence_status",
    "native_control_evidence",
    "openracing_hardware_output",
    "openracing_hid_device_opened",
    "openracing_ffb_writes",
    "openracing_output_reports",
    "openracing_feature_reports",
    "openracing_serial_config_commands",
    "openracing_firmware_or_dfu_commands",
    "external_app_observed",
    "external_app_may_have_sent_output",
    "satisfies_native_response_ready",
    "satisfies_native_visible_ready",
    "satisfies_smoke_ready",
    "satisfies_release_ready",
    "readiness_claims"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "success": {
      "type": "boolean"
    },
    "command": {
      "type": "string",
      "const": "wheelctl hardware sniff-receipt"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "plan_path": {
      "type": "string",
      "minLength": 1
    },
    "pcapng_path": {
      "type": "string",
      "pattern": "\\.pcapng$"
    },
    "pcapng_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "pcapng_size_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "operator": {
      "type": "string",
      "minLength": 1
    },
    "app": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "$ref": "#/$defs/scenario"
    },
    "device_note": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "evidence_status": {
      "type": "string",
      "const": "passive_external_usb_observation"
    },
    "native_control_evidence": {
      "type": "boolean",
      "const": false
    },
    "openracing_hardware_output": {
      "type": "boolean",
      "const": false
    },
    "openracing_hid_device_opened": {
      "type": "boolean",
      "const": false
    },
    "openracing_ffb_writes": {
      "type": "boolean",
      "const": false
    },
    "openracing_output_reports": {
      "type": "boolean",
      "const": false
    },
    "openracing_feature_reports": {
      "type": "boolean",
      "const": false
    },
    "openracing_serial_config_commands": {
      "type": "boolean",
      "const": false
    },
    "openracing_firmware_or_dfu_commands": {
      "type": "boolean",
      "const": false
    },
    "external_app_observed": {
      "type": "boolean"
    },
    "external_app_may_have_sent_output": {
      "type": "boolean"
    },
    "satisfies_native_response_ready": {
      "type": "boolean",
      "const": false
    },
    "satisfies_native_visible_ready": {
      "type": "boolean",
      "const": false
    },
    "satisfies_smoke_ready": {
      "type": "boolean",
      "const": false
    },
    "satisfies_release_ready": {
      "type": "boolean",
      "const": false
    },
    "readiness_claims": {
      "$ref": "#/$defs/readiness_claims"
    }
  },
  "$defs": {
    "scenario": {
      "type": "string",
      "enum": [
        "enumeration",
        "vendor-app-closed-idle",
        "pit-house-open-idle",
        "pit-house-setting-change",
        "pit-house-firmware-page-observed",
        "simhub-open-idle",
        "simhub-device-detect",
        "simhub-output-session",
        "simulator-session-start-stop",
        "custom"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "readiness_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "satisfies_native_response_ready",
        "satisfies_native_visible_ready",
        "satisfies_smoke_ready",
        "satisfies_release_ready"
      ],
      "properties": {
        "satisfies_native_response_ready": {
          "type": "boolean",
          "const": false
        },
        "satisfies_native_visible_ready": {
          "type": "boolean",
          "const": false
        },
        "satisfies_smoke_ready": {
          "type": "boolean",
          "const": false
        },
        "satisfies_release_ready": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
