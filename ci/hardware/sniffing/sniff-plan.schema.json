{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.local/schemas/hardware/sniffing/sniff-plan.schema.json",
  "title": "OpenRacing Passive USB Sniff Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "success",
    "command",
    "generated_at_utc",
    "family",
    "scenario",
    "lane",
    "operator",
    "device_note",
    "capture_kind",
    "capture_tools",
    "platform_hint",
    "allowed_actions",
    "forbidden_actions",
    "pre_capture_checklist",
    "post_capture_checklist",
    "operator_notes_required",
    "raw_pcap_commit_default",
    "evidence_status",
    "native_control_evidence",
    "openracing_hardware_output",
    "external_app_may_have_sent_output",
    "satisfies_native_response_ready",
    "satisfies_native_visible_ready",
    "satisfies_smoke_ready",
    "satisfies_release_ready",
    "readiness_claims",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "success": {
      "type": "boolean"
    },
    "command": {
      "type": "string",
      "const": "wheelctl hardware sniff-plan"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "$ref": "#/$defs/scenario"
    },
    "lane": {
      "type": "string",
      "minLength": 1
    },
    "operator": {
      "type": "string",
      "minLength": 1
    },
    "device_note": {
      "type": "string",
      "minLength": 1
    },
    "capture_kind": {
      "type": "string",
      "const": "software_usb_urb_capture"
    },
    "capture_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["wireshark", "usbpcap", "tshark", "usbmon"]
      },
      "uniqueItems": true
    },
    "platform_hint": {
      "type": "string",
      "enum": ["windows", "linux", "macos", "unknown"]
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "install Zadig"
          }
        },
        {
          "contains": {
            "const": "replace HID driver"
          }
        },
        {
          "contains": {
            "const": "switch device to WinUSB"
          }
        },
        {
          "contains": {
            "const": "run OpenRacing output commands"
          }
        },
        {
          "contains": {
            "const": "send OpenRacing HID output reports"
          }
        },
        {
          "contains": {
            "const": "send OpenRacing HID feature reports"
          }
        },
        {
          "contains": {
            "const": "touch serial configuration"
          }
        },
        {
          "contains": {
            "const": "open firmware update flows"
          }
        },
        {
          "contains": {
            "const": "run firmware or DFU tools"
          }
        }
      ]
    },
    "pre_capture_checklist": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "keep OpenRacing hardware output commands stopped for this passive capture"
          }
        },
        {
          "contains": {
            "const": "keep firmware, update, DFU, driver replacement, Zadig, and WinUSB conversion flows closed"
          }
        }
      ]
    },
    "post_capture_checklist": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "record operator notes before bundling"
          }
        },
        {
          "contains": {
            "const": "run sniff-receipt, sniff-notes-template, and sniff-summary before treating the capture as lane evidence"
          }
        },
        {
          "contains": {
            "const": "do not commit raw pcapng unless it is separately reviewed for size, sensitivity, and operator consent"
          }
        }
      ]
    },
    "operator_notes_required": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "scenario performed"
          }
        },
        {
          "contains": {
            "const": "device stack attached"
          }
        },
        {
          "contains": {
            "const": "whether firmware/update/DFU pages stayed closed"
          }
        }
      ]
    },
    "raw_pcap_commit_default": {
      "type": "boolean",
      "const": false
    },
    "evidence_status": {
      "type": "string",
      "const": "passive_external_usb_observation"
    },
    "native_control_evidence": {
      "type": "boolean",
      "const": false
    },
    "openracing_hardware_output": {
      "type": "boolean",
      "const": false
    },
    "external_app_may_have_sent_output": {
      "type": "boolean"
    },
    "satisfies_native_response_ready": {
      "type": "boolean",
      "const": false
    },
    "satisfies_native_visible_ready": {
      "type": "boolean",
      "const": false
    },
    "satisfies_smoke_ready": {
      "type": "boolean",
      "const": false
    },
    "satisfies_release_ready": {
      "type": "boolean",
      "const": false
    },
    "readiness_claims": {
      "$ref": "#/$defs/readiness_claims"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scenario": {
            "const": "pit-house-setting-change"
          }
        },
        "required": ["scenario"]
      },
      "then": {
        "properties": {
          "operator_notes_required": {
            "allOf": [
              {
                "contains": {
                  "const": "exact Pit House setting changed"
                }
              },
              {
                "contains": {
                  "const": "starting setting value"
                }
              },
              {
                "contains": {
                  "const": "ending setting value"
                }
              },
              {
                "contains": {
                  "const": "whether the setting value was restored"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scenario": {
            "const": "pit-house-0x8e-timing-correlation"
          }
        },
        "required": ["scenario"]
      },
      "then": {
        "properties": {
          "operator_notes_required": {
            "allOf": [
              {
                "contains": {
                  "const": "hardware_doctor_selector_reviewed_utc"
                }
              },
              {
                "contains": {
                  "const": "capture_start_utc"
                }
              },
              {
                "contains": {
                  "const": "pit_house_opened_utc"
                }
              },
              {
                "contains": {
                  "const": "r5_recognized_in_pit_house_utc"
                }
              },
              {
                "contains": {
                  "const": "idle_stable_before_change_utc"
                }
              },
              {
                "contains": {
                  "const": "ks_top_left_front_led_default_teal_observed_utc"
                }
              },
              {
                "contains": {
                  "const": "ks_top_left_front_led_changed_to_red_utc"
                }
              },
              {
                "contains": {
                  "const": "ks_top_left_front_led_restored_to_default_teal_utc"
                }
              },
              {
                "contains": {
                  "const": "idle_stable_after_restore_utc"
                }
              },
              {
                "contains": {
                  "const": "pit_house_closed_utc"
                }
              },
              {
                "contains": {
                  "const": "capture_stop_utc"
                }
              },
              {
                "contains": {
                  "const": "fresh hardware doctor path and USBPcap selector used"
                }
              },
              {
                "contains": {
                  "const": "exact setting changed: KS top-left front LED"
                }
              },
              {
                "contains": {
                  "const": "starting setting value: default teal"
                }
              },
              {
                "contains": {
                  "const": "ending setting value: red"
                }
              },
              {
                "contains": {
                  "const": "restored setting value: default teal"
                }
              },
              {
                "contains": {
                  "const": "OpenRacing sent no HID/output/feature/serial/firmware commands"
                }
              }
            ]
          },
          "pre_capture_checklist": {
            "allOf": [
              {
                "contains": {
                  "const": "refresh hardware doctor immediately before capture and use its current USBPcap Moza selector hint"
                }
              },
              {
                "contains": {
                  "const": "do not reuse stale USBPcap --devices values from earlier captures"
                }
              },
              {
                "contains": {
                  "const": "change only the KS wheel top-left front LED from default teal to red and back to default teal"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scenario": {
            "const": "simhub-open-idle"
          }
        },
        "required": ["scenario"]
      },
      "then": {
        "properties": {
          "operator_notes_required": {
            "allOf": [
              {
                "contains": {
                  "const": "SimHub version/source if known"
                }
              },
              {
                "contains": {
                  "const": "SimHub launch/open time"
                }
              },
              {
                "contains": {
                  "const": "SimHub idle/stable confirmation"
                }
              },
              {
                "contains": {
                  "const": "no SimHub output session started"
                }
              },
              {
                "contains": {
                  "const": "no simulator started"
                }
              },
              {
                "contains": {
                  "const": "firmware/update/DFU pages stayed closed or no prompt/page observed"
                }
              },
              {
                "contains": {
                  "const": "raw pcap kept local only"
                }
              },
              {
                "contains": {
                  "const": "OpenRacing sent no HID/output/feature/serial/firmware commands"
                }
              }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "scenario": {
      "type": "string",
      "enum": [
        "enumeration",
        "vendor-app-closed-idle",
        "pit-house-open-idle",
        "pit-house-full-controls",
        "pit-house-setting-change",
        "pit-house-0x8e-timing-correlation",
        "pit-house-firmware-page-observed",
        "simhub-open-idle",
        "simhub-device-detect",
        "simhub-output-session",
        "simulator-session-start-stop",
        "custom"
      ]
    },
    "readiness_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "satisfies_native_response_ready",
        "satisfies_native_visible_ready",
        "satisfies_smoke_ready",
        "satisfies_release_ready"
      ],
      "properties": {
        "satisfies_native_response_ready": {
          "type": "boolean",
          "const": false
        },
        "satisfies_native_visible_ready": {
          "type": "boolean",
          "const": false
        },
        "satisfies_smoke_ready": {
          "type": "boolean",
          "const": false
        },
        "satisfies_release_ready": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
