{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-timing-correlation-review.schema.json",
  "title": "Moza R5 0x8E timing-correlation review receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "semantic_review_receipt",
    "sniff_summary",
    "operator_notes",
    "capture_provenance_inputs_provided",
    "capture_provenance_verified",
    "capture_provenance_required_for_candidate",
    "capture_provenance_status",
    "capture_provenance",
    "target_group_id",
    "target_tuple_ids",
    "target_tuple_reviews",
    "operator_event_markers_required",
    "operator_event_markers_missing",
    "operator_event_marker_notes_complete",
    "operator_event_marker_timestamps_present",
    "operator_event_marker_timestamps_missing",
    "operator_event_marker_timestamps_complete",
    "operator_event_marker_order_valid",
    "operator_event_marker_order_violations",
    "operator_event_marker_correlation_scope",
    "operator_event_marker_correlation_markers_allowed",
    "operator_event_marker_correlation_markers_ignored",
    "event_correlation_window_seconds",
    "summary_has_packet_timestamp_samples",
    "target_sample_timestamp_count",
    "target_samples_within_capture_window",
    "target_samples_outside_capture_window",
    "any_target_samples_observed",
    "same_tuple_payload_variation_observed",
    "operator_event_marker_correlation_observed",
    "same_tuple_payload_variation_with_event_markers_observed",
    "timing_correlation_candidate_observed",
    "timing_correlation_candidate_without_capture_provenance",
    "timing_correlation_proven",
    "timing_correlation_verdict",
    "payload_bearing_authority_state_source_found",
    "live_read_only_probe_allowed",
    "authorization_plan_allowed",
    "motion_attempt_allowed",
    "hardware_output_authorized",
    "native_control_evidence",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": {
      "const": "moza_vendor_status_timing_correlation_review"
    },
    "claim_scope": {
      "const": "no_output_0x8e_timing_correlation_review"
    },
    "command": {
      "const": "wheelctl moza vendor-status-timing-correlation-review"
    },
    "target_group_id": {
      "const": "passive_payload_bearing_status_source_0x8e"
    },
    "target_tuple_ids": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "0x8E/0x21/0x00" } },
        { "contains": { "const": "0x8E/0x31/0x00" } },
        { "contains": { "const": "0x8E/0x71/0x00" } },
        { "contains": { "const": "0x8E/0x91/0x00" } }
      ]
    },
    "target_tuple_reviews": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "tuple_id",
          "summary_observed_sample_count",
          "summary_observed_payload_hex_values",
          "same_tuple_payload_variation_observed",
          "operator_event_marker_correlation_observed",
          "same_tuple_payload_variation_with_event_markers_observed",
          "correlated_sample_count",
          "correlated_operator_event_markers",
          "correlated_payload_hex_values",
          "correlated_samples",
          "timing_correlation_status",
          "risk_class",
          "semantic_decode_claim",
          "registry_promotion_claim",
          "output_sendability_claim",
          "read_only_probe_allowed",
          "hardware_output_authorized",
          "native_control_evidence"
        ],
        "properties": {
          "tuple_id": {
            "enum": [
              "0x8E/0x21/0x00",
              "0x8E/0x31/0x00",
              "0x8E/0x71/0x00",
              "0x8E/0x91/0x00"
            ]
          },
          "risk_class": { "const": "unknown_do_not_send" },
          "semantic_decode_claim": { "const": false },
          "registry_promotion_claim": { "const": false },
          "output_sendability_claim": { "const": false },
          "read_only_probe_allowed": { "const": false },
          "hardware_output_authorized": { "const": false },
          "native_control_evidence": { "const": false },
          "operator_event_marker_correlation_observed": { "type": "boolean" },
          "same_tuple_payload_variation_with_event_markers_observed": {
            "type": "boolean"
          },
          "correlated_sample_count": { "type": "integer", "minimum": 0 },
          "correlated_operator_event_markers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "correlated_payload_hex_values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "correlated_samples": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "operator_event_marker_notes_complete": { "type": "boolean" },
    "operator_event_marker_timestamps_present": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operator_event_marker_timestamps_missing": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operator_event_marker_timestamps_complete": { "type": "boolean" },
    "operator_event_marker_order_valid": { "type": "boolean" },
    "operator_event_marker_order_violations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "operator_event_marker_correlation_scope": {
      "const": "semantic_operator_events_only"
    },
    "operator_event_marker_correlation_markers_allowed": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "pit_house_opened_utc" } },
        { "contains": { "const": "r5_recognized_in_pit_house_utc" } },
        { "contains": { "const": "idle_stable_before_change_utc" } },
        { "contains": { "const": "ks_top_left_front_led_default_teal_observed_utc" } },
        { "contains": { "const": "ks_top_left_front_led_changed_to_red_utc" } },
        { "contains": { "const": "ks_top_left_front_led_restored_to_default_teal_utc" } },
        { "contains": { "const": "idle_stable_after_restore_utc" } },
        { "contains": { "const": "pit_house_closed_utc" } }
      ]
    },
    "operator_event_marker_correlation_markers_ignored": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "capture_start_utc" } },
        { "contains": { "const": "hardware_doctor_selector_reviewed_utc" } },
        { "contains": { "const": "capture_stop_utc" } }
      ]
    },
    "event_correlation_window_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "summary_has_packet_timestamp_samples": { "type": "boolean" },
    "capture_provenance_inputs_provided": { "type": "boolean" },
    "capture_provenance_verified": { "type": "boolean" },
    "capture_provenance_required_for_candidate": { "const": true },
    "capture_provenance_status": {
      "enum": ["not_provided", "verified"]
    },
    "capture_provenance": {
      "type": "object",
      "required": [
        "capture_provenance_inputs_provided",
        "capture_provenance_verified",
        "capture_provenance_required_for_candidate",
        "capture_provenance_status"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "capture_provenance_status": { "const": "verified" }
            },
            "required": ["capture_provenance_status"]
          },
          "then": {
            "required": [
              "capture_hardware_doctor_generated_at_utc",
              "capture_hardware_doctor_age_seconds",
              "capture_hardware_doctor_freshness_max_age_minutes"
            ]
          }
        }
      ],
      "properties": {
        "capture_provenance_required_for_candidate": { "const": true },
        "capture_provenance_verified": { "type": "boolean" },
        "capture_hardware_doctor_generated_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "capture_hardware_doctor_age_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 600
        },
        "capture_hardware_doctor_freshness_max_age_minutes": {
          "const": 10
        },
        "hardware_output_authorized": { "const": false },
        "native_control_evidence": { "const": false },
        "native_visible_ready": { "const": false },
        "output_was_sent": { "const": false }
      }
    },
    "target_sample_timestamp_count": { "type": "integer", "minimum": 0 },
    "target_samples_within_capture_window": { "type": "boolean" },
    "target_samples_outside_capture_window": {
      "type": "array",
      "items": { "type": "object" }
    },
    "any_target_samples_observed": { "type": "boolean" },
    "same_tuple_payload_variation_observed": { "type": "boolean" },
    "operator_event_marker_correlation_observed": { "type": "boolean" },
    "same_tuple_payload_variation_with_event_markers_observed": {
      "type": "boolean"
    },
    "timing_correlation_candidate_observed": { "type": "boolean" },
    "timing_correlation_candidate_without_capture_provenance": {
      "type": "boolean"
    },
    "timing_correlation_proven": { "const": false },
    "payload_bearing_authority_state_source_found": { "const": false },
    "reviewed_equivalent_status_source_found": { "const": false },
    "corrected_read_only_probe_ready": { "const": false },
    "live_read_only_probe_allowed": { "const": false },
    "authorization_plan_allowed": { "const": false },
    "motion_attempt_allowed": { "const": false },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "release_ready": { "const": false },
    "registry_promotion_claim": { "const": false },
    "output_sendability_claim": { "const": false },
    "semantic_decode_claim": { "const": false },
    "wheel_moved_under_openracing": { "const": false },
    "visible_motion_verified": { "const": false },
    "output_was_sent": { "const": false },
    "authority_state": { "const": "blocked" },
    "no_hid_device_opened": { "const": true },
    "opened_serial_device": { "const": false },
    "sent_read_only_query_commands": { "const": false },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "mode_enable_candidates_sendable": { "const": false },
    "planned_next_output_allowed": { "const": false },
    "unknown_safety_or_mode_state_blocks_authority": { "const": true },
    "blocked_actions": {
      "type": "array",
      "contains": { "const": "hardware writes" }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1
    }
  }
}
