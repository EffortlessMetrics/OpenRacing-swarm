{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-no-output-cli.schema.json",
  "title": "Moza Vendor No-Output CLI Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "no_hid_device_opened",
    "opened_serial_device",
    "no_ffb_writes",
    "no_output_reports",
    "no_feature_reports",
    "no_serial_config_commands",
    "no_firmware_or_dfu_commands",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "real_hardware_validated",
    "transport_kind",
    "fake_transport_verified",
    "codec_status",
    "hardware_write_eligible",
    "accepted_fixture_count",
    "blocked_fixture_count",
    "malformed_frame_rejected",
    "unknown_command_rejected"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_no_output_cli"},
    "claim_scope": {"const": "software_cli_fake_transport_only"},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": false},
    "native_visible_ready": {"const": false},
    "next_allowed_action": {"type": "string"},
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "no_hid_device_opened": {"const": true},
    "opened_serial_device": {"const": false},
    "no_ffb_writes": {"const": true},
    "no_output_reports": {"const": true},
    "no_feature_reports": {"const": true},
    "no_serial_config_commands": {"const": true},
    "no_firmware_or_dfu_commands": {"const": true},
    "sent_read_only_query_commands": {"const": false},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "real_hardware_validated": {"const": false},
    "transport_kind": {"const": "fake_only"},
    "fake_transport_verified": {"const": true},
    "codec_status": {"const": "round_trip_verified"},
    "hardware_write_eligible": {"const": false},
    "accepted_fixture_count": {"type": "integer", "minimum": 1},
    "blocked_fixture_count": {"type": "integer", "minimum": 1},
    "malformed_frame_rejected": {"const": true},
    "unknown_command_rejected": {"const": true}
  },
  "additionalProperties": true
}
