{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-authority-authorization.schema.json",
  "title": "Moza vendor authority exact authorization receipt",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "generated_at_utc",
    "expires_at_utc",
    "expires_after_minutes",
    "authorized_by",
    "bench_clear_evidence",
    "precondition_hardware_doctor_receipt",
    "precondition_hardware_doctor_validated",
    "precondition_generated_at",
    "precondition_max_age_minutes",
    "precondition_r5_serial_present",
    "precondition_r5_serial_port",
    "precondition_r5_serial_interface",
    "precondition_vendor_app_scan_attempted",
    "precondition_vendor_app_running",
    "precondition_vendor_app_matched_processes",
    "precondition_no_hid_device_opened",
    "precondition_no_ffb_writes",
    "precondition_no_output_reports",
    "precondition_no_feature_reports",
    "precondition_no_serial_config_commands",
    "precondition_no_firmware_or_dfu_commands",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "authorization_consumed",
    "exact_authorization",
    "single_use",
    "no_hid_device_opened",
    "no_serial_device_opened",
    "no_serial_query_sent",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "transport_kind",
    "codec_status",
    "hardware_write_eligible",
    "authorized_command",
    "authorized_frame",
    "forbidden_commands"
  ],
  "properties": {
    "success": {"const": true},
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_authority_authorization"},
    "claim_scope": {"const": "single_use_exact_vendor_authority_authorization"},
    "command": {"const": "wheelctl moza authorize-vendor-authority"},
    "generated_at_utc": {"type": "string"},
    "expires_at_utc": {"type": "string"},
    "expires_after_minutes": {"type": "integer", "minimum": 1, "maximum": 60},
    "authorized_by": {"type": "string", "minLength": 1},
    "bench_clear_evidence": {"type": "string", "minLength": 1},
    "precondition_hardware_doctor_receipt": {"type": "string", "minLength": 1},
    "precondition_hardware_doctor_validated": {"const": true},
    "precondition_generated_at": {"type": "string"},
    "precondition_max_age_minutes": {"type": "integer", "minimum": 1, "maximum": 60},
    "precondition_r5_serial_present": {"const": true},
    "precondition_r5_serial_port": {"type": "string", "pattern": "^COM[0-9]+$"},
    "precondition_r5_serial_interface": {"type": "string", "minLength": 1},
    "precondition_vendor_app_scan_attempted": {"const": true},
    "precondition_vendor_app_running": {"const": false},
    "precondition_vendor_app_matched_processes": {
      "type": "array",
      "maxItems": 0,
      "items": {"type": "string"}
    },
    "precondition_no_hid_device_opened": {"const": true},
    "precondition_no_ffb_writes": {"const": true},
    "precondition_no_output_reports": {"const": true},
    "precondition_no_feature_reports": {"const": true},
    "precondition_no_serial_config_commands": {"const": true},
    "precondition_no_firmware_or_dfu_commands": {"const": true},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": true},
    "native_visible_ready": {"const": false},
    "next_allowed_action": {"type": "string"},
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "authorization_consumed": {"const": false},
    "exact_authorization": {"const": true},
    "single_use": {"const": true},
    "no_hid_device_opened": {"const": true},
    "no_serial_device_opened": {"const": true},
    "no_serial_query_sent": {"const": true},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "transport_kind": {"const": "authorization_receipt_only"},
    "codec_status": {"const": "fixture_decode_verified_exact_frame"},
    "hardware_write_eligible": {"const": true},
    "authorized_command": {
      "type": "object",
      "required": [
        "command_id",
        "command_name",
        "family",
        "group",
        "device_id",
        "command",
        "risk_class",
        "read_only_status_probe_allowed"
      ],
      "properties": {
        "command_id": {"type": "string"},
        "command_name": {"type": "string"},
        "family": {"type": "string"},
        "group": {"type": "integer", "minimum": 0, "maximum": 255},
        "device_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "command": {"type": "integer", "minimum": 0, "maximum": 255},
        "risk_class": {
          "enum": [
            "vendor_control_candidate",
            "vendor_output_candidate",
            "configuration_candidate"
          ]
        },
        "read_only_status_probe_allowed": {"const": false}
      },
      "additionalProperties": true
    },
    "authorized_frame": {
      "type": "object",
      "required": [
        "frame_hex",
        "frame_sha256",
        "frame_len",
        "payload_hex",
        "payload_sha256",
        "payload_len",
        "checksum"
      ],
      "properties": {
        "frame_hex": {"type": "string"},
        "frame_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "frame_len": {"type": "integer", "minimum": 7},
        "payload_hex": {"type": "string"},
        "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "payload_len": {"type": "integer", "minimum": 1},
        "checksum": {"type": "string", "pattern": "^0x[0-9A-F]{2}$"}
      },
      "additionalProperties": true
    },
    "forbidden_commands": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
