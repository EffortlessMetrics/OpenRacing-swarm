{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-authority-source-gap.schema.json",
  "title": "Moza Vendor Authority Status Source Gap",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "endpoint_candidates_receipt",
    "protocol_evidence_review_receipt",
    "source_review_count",
    "source_reviews",
    "payload_bearing_authority_state_source_found",
    "reviewed_equivalent_status_source_found",
    "corrected_read_only_probe_ready",
    "live_read_only_probe_allowed",
    "authorization_plan_allowed",
    "motion_attempt_allowed",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "semantic_decode_claim",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "no_hid_device_opened",
    "opened_serial_device",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "mode_enable_candidates_sendable",
    "planned_next_output_allowed",
    "unknown_safety_or_mode_state_blocks_authority",
    "exact_next_blocker",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": { "const": "moza_vendor_status_authority_source_gap" },
    "claim_scope": { "const": "no_output_authority_status_source_gap_review" },
    "command": { "const": "wheelctl moza vendor-status-authority-source-gap" },
    "endpoint_candidates_receipt": { "type": "string" },
    "protocol_evidence_review_receipt": { "type": "string" },
    "source_review_count": { "const": 4 },
    "source_reviews": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "source_kind",
          "input_artifact",
          "observed_payload_bearing_authority_state_source",
          "classification",
          "read_only_probe_allowed",
          "required_next_review"
        ],
        "properties": {
          "source_id": { "type": "string" },
          "source_kind": { "type": "string" },
          "input_artifact": { "type": "string" },
          "observed_payload_bearing_authority_state_source": { "const": false },
          "classification": { "type": "string" },
          "read_only_probe_allowed": { "const": false },
          "required_next_review": { "type": "string" }
        },
        "additionalProperties": true
      },
      "contains": {
        "type": "object",
        "required": [
          "source_id",
          "device_to_host_serial_tuple_details_present",
          "total_device_to_host_serial_frame_count",
          "device_to_host_serial_frame_sample_scope",
          "device_to_host_serial_frame_tuple_ids",
          "device_to_host_serial_frame_tuple_sample_count"
        ],
        "properties": {
          "source_id": { "const": "passive_device_to_host_response_source" },
          "device_to_host_serial_tuple_details_present": { "const": true },
          "total_device_to_host_serial_frame_count": {
            "type": "integer",
            "minimum": 1
          },
          "device_to_host_serial_frame_sample_scope": {
            "const": "observed_report_payload_hex_samples_only"
          },
          "device_to_host_serial_frame_tuple_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "device_to_host_serial_frame_tuple_sample_count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "payload_bearing_authority_state_source_found": { "const": false },
    "reviewed_equivalent_status_source_found": { "const": false },
    "corrected_read_only_probe_ready": { "const": false },
    "live_read_only_probe_allowed": { "const": false },
    "authorization_plan_allowed": { "const": false },
    "motion_attempt_allowed": { "const": false },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "release_ready": { "const": false },
    "registry_promotion_claim": { "const": false },
    "output_sendability_claim": { "const": false },
    "semantic_decode_claim": { "const": false },
    "wheel_moved_under_openracing": { "const": false },
    "visible_motion_verified": { "const": false },
    "output_was_sent": { "const": false },
    "authority_state": { "const": "blocked" },
    "no_hid_device_opened": { "const": true },
    "opened_serial_device": { "const": false },
    "sent_read_only_query_commands": { "const": false },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "mode_enable_candidates_sendable": { "const": false },
    "planned_next_output_allowed": { "const": false },
    "unknown_safety_or_mode_state_blocks_authority": { "const": true },
    "exact_next_blocker": { "type": "string" },
    "next_allowed_action": { "type": "string" },
    "blocked_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
