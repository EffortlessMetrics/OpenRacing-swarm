{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "candidate_sequence"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_authority_plan"},
    "claim_scope": {"const": "software_no_output"},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": false},
    "native_visible_ready": {"const": false},
    "next_allowed_action": {"type": "string"},
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "candidate_sequence": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
