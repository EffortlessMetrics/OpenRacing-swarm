{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-command-registry.schema.json",
  "title": "Moza Vendor Command Registry",
  "type": "object",
  "required": ["schema_version","artifact_kind","claim_scope","native_control_evidence","hardware_output_authorized","device","commands"],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_command_registry"},
    "claim_scope": {"const": "protocol_research_only"},
    "native_control_evidence": {"type":"boolean"},
    "hardware_output_authorized": {"const": false},
    "device": {"type":"object"},
    "commands": {"type":"array","minItems":1}
  },
  "additionalProperties": true
}
