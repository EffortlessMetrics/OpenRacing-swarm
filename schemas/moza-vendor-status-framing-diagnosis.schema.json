{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-framing-diagnosis.schema.json",
  "title": "Moza Vendor Status Framing Diagnosis Receipt",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "status_probe_receipt",
    "status_probe_success",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "semantic_decode_claim",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "no_hid_device_opened",
    "opened_serial_device",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "mode_enable_candidates_sendable",
    "planned_next_output_allowed",
    "unknown_safety_or_mode_state_blocks_authority",
    "diagnosis_classification",
    "primary_blocker",
    "response_frame_count",
    "registry_status_response_count",
    "framed_ascii_telemetry_log_count",
    "desynchronized_or_partial_frame_count",
    "checksum_valid_count",
    "checksum_invalid_count",
    "diagnosed_responses",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": {"const": true},
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_status_framing_diagnosis"},
    "claim_scope": {"const": "no_output_read_only_serial_response_framing_diagnosis"},
    "command": {"const": "wheelctl moza vendor-status-framing-diagnosis"},
    "status_probe_receipt": {"type": "string"},
    "status_probe_success": {"type": "boolean"},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": false},
    "native_visible_ready": {"const": false},
    "smoke_ready": {"const": false},
    "release_ready": {"const": false},
    "registry_promotion_claim": {"const": false},
    "output_sendability_claim": {"const": false},
    "semantic_decode_claim": {"const": false},
    "wheel_moved_under_openracing": {"const": false},
    "visible_motion_verified": {"const": false},
    "output_was_sent": {"const": false},
    "authority_state": {"const": "blocked"},
    "no_hid_device_opened": {"const": true},
    "opened_serial_device": {"const": false},
    "sent_read_only_query_commands": {"const": false},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "high_torque_enabled": {"const": false},
    "mode_enable_candidates_sendable": {"const": false},
    "planned_next_output_allowed": {"const": false},
    "unknown_safety_or_mode_state_blocks_authority": {"const": true},
    "diagnosis_classification": {
      "enum": [
        "authority_status_endpoint_specific_ack_only_without_payload",
        "authority_status_endpoint_specific_debug_telemetry_without_payload",
        "authority_status_endpoint_specific_no_payload_after_targeted_read_only_probe",
        "serial_readback_consumed_debug_telemetry_log_frames",
        "authority_status_replies_uncorrelated_after_targeted_read_only_probe",
        "authority_status_replies_zero_length_ack_candidate_after_targeted_read_only_probe",
        "authority_status_ack_only_without_payload_after_targeted_read_only_probe",
        "no_response_frames_captured",
        "all_response_frames_are_registry_status_responses",
        "mixed_or_unknown_serial_response_stream"
      ]
    },
    "primary_blocker": {"type": "string"},
    "baseline_status_probe_summary": {
      "type": "object",
      "required": [
        "receipt",
        "selected_command_count",
        "decoded_response_count",
        "failed_response_count",
        "authority_status_command_count",
        "authority_status_decoded_response_count",
        "non_authority_decoded_response_count"
      ],
      "properties": {
        "receipt": {"type": "string"},
        "selected_command_count": {"type": "integer", "minimum": 0},
        "decoded_response_count": {"type": "integer", "minimum": 0},
        "failed_response_count": {"type": "integer", "minimum": 0},
        "authority_status_command_count": {"type": "integer", "minimum": 0},
        "authority_status_decoded_response_count": {"type": "integer", "minimum": 0},
        "authority_status_failed_response_count": {"type": "integer", "minimum": 0},
        "authority_status_command_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "non_authority_command_count": {"type": "integer", "minimum": 0},
        "non_authority_decoded_response_count": {"type": "integer", "minimum": 0},
        "non_authority_failed_response_count": {"type": "integer", "minimum": 0},
        "non_authority_command_ids": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "status_probe_authority_status_command_count": {"type": "integer", "minimum": 0},
    "status_probe_authority_status_decoded_response_count": {"type": "integer", "minimum": 0},
    "status_probe_non_authority_decoded_response_count": {"type": "integer", "minimum": 0},
    "broad_serial_transport_blocker_ruled_out": {"type": "boolean"},
    "authority_status_endpoint_specific_blocker": {"type": "boolean"},
    "endpoint_or_command_correction_required": {"type": "boolean"},
    "response_frame_count": {"type": "integer", "minimum": 0},
    "registry_status_response_count": {"type": "integer", "minimum": 0},
    "framed_ascii_telemetry_log_count": {"type": "integer", "minimum": 0},
    "zero_length_response_or_ack_frame_count": {"type": "integer", "minimum": 0},
    "desynchronized_or_partial_frame_count": {"type": "integer", "minimum": 0},
    "malformed_frame_count": {"type": "integer", "minimum": 0},
    "unknown_non_registry_frame_count": {"type": "integer", "minimum": 0},
    "checksum_valid_count": {"type": "integer", "minimum": 0},
    "checksum_invalid_count": {"type": "integer", "minimum": 0},
    "scanned_response_frame_count": {"type": "integer", "minimum": 0},
    "scanned_registry_status_response_count": {"type": "integer", "minimum": 0},
    "scanned_framed_ascii_telemetry_log_count": {"type": "integer", "minimum": 0},
    "scanned_zero_length_response_or_ack_frame_count": {"type": "integer", "minimum": 0},
    "scanned_desynchronized_or_partial_frame_count": {"type": "integer", "minimum": 0},
    "scanned_malformed_frame_count": {"type": "integer", "minimum": 0},
    "scanned_unknown_non_registry_frame_count": {"type": "integer", "minimum": 0},
    "scanned_checksum_valid_count": {"type": "integer", "minimum": 0},
    "scanned_checksum_invalid_count": {"type": "integer", "minimum": 0},
    "scanned_response_like_command_mismatch_count": {"type": "integer", "minimum": 0},
    "scanned_response_like_zero_length_frame_count": {"type": "integer", "minimum": 0},
    "response_like_zero_length_ack_only_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "response_like_command_mismatch_tuples": {
      "type": "array",
      "items": {"type": "object"}
    },
    "response_like_zero_length_tuples": {
      "type": "array",
      "items": {"type": "object"}
    },
    "diagnosed_responses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "query_frame_hex",
          "expected_tuple_id",
          "response_classification",
          "actual_len",
          "length_matches",
          "registry_command_known",
          "printable_ascii_payload",
          "nrfloss_recv_gap_payload",
          "embedded_start_byte_count"
        ],
        "properties": {
          "command_id": {"type": "string"},
          "query_frame_hex": {"type": "string"},
          "response_frame_hex": {"type": "string"},
          "expected_tuple_id": {"type": "string"},
          "observed_tuple_id": {"type": "string"},
          "response_classification": {"type": "string"},
          "actual_len": {"type": "integer", "minimum": 0},
          "declared_len": {"type": "integer", "minimum": 0},
          "expected_len": {"type": "integer", "minimum": 0},
          "length_matches": {"type": "boolean"},
          "checksum_valid": {"type": "boolean"},
          "registry_command_known": {"type": "boolean"},
          "printable_ascii_payload": {"type": "boolean"},
          "nrfloss_recv_gap_payload": {"type": "boolean"},
          "embedded_start_byte_count": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": true
      }
    },
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "exact_next_blocker": {"type": "string"}
  },
  "additionalProperties": true
}
