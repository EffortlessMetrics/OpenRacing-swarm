{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-response-semantic-fixtures.schema.json",
  "title": "Moza Vendor Status Correlated Response Semantic Fixtures",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "response_correlation_receipt",
    "protocol_evidence_review_receipt",
    "fixture_decoder_coverage_recorded",
    "decoded_response_fixture_tuple_ids",
    "decoded_response_fixture_group_ids",
    "decoded_response_fixture_sample_count",
    "zero_filled_payload_sample_count",
    "all_correlated_payloads_zero_filled",
    "payload_variation_observed",
    "nonzero_payload_tuple_ids",
    "decoded_response_fixture_samples",
    "payload_bearing_authority_state_source_found",
    "reviewed_equivalent_status_source_found",
    "corrected_read_only_probe_ready",
    "live_read_only_probe_allowed",
    "authorization_plan_allowed",
    "motion_attempt_allowed",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "semantic_decode_claim",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "no_hid_device_opened",
    "opened_serial_device",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "mode_enable_candidates_sendable",
    "planned_next_output_allowed",
    "unknown_safety_or_mode_state_blocks_authority",
    "zero_response_diagnosis",
    "exact_next_blocker",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": {
      "const": "moza_vendor_status_response_semantic_fixtures"
    },
    "claim_scope": {
      "const": "no_output_correlated_passive_response_fixture_review"
    },
    "command": {
      "const": "wheelctl moza vendor-status-response-semantic-fixtures"
    },
    "response_correlation_receipt": { "type": "string" },
    "protocol_evidence_review_receipt": { "type": "string" },
    "fixture_decoder_coverage_recorded": { "const": true },
    "decoded_response_fixture_tuple_ids": {
      "type": "array",
      "minItems": 5,
      "items": { "type": "string" }
    },
    "decoded_response_fixture_group_ids": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" },
      "contains": { "const": "passive_session_authority_pair_0x5a_0x5d" }
    },
    "decoded_response_fixture_sample_count": { "type": "integer", "minimum": 1 },
    "zero_filled_payload_sample_count": { "type": "integer", "minimum": 1 },
    "all_correlated_payloads_zero_filled": { "const": true },
    "payload_variation_observed": { "const": false },
    "nonzero_payload_tuple_ids": {
      "type": "array",
      "maxItems": 0,
      "items": { "type": "string" }
    },
    "decoded_response_fixture_samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scenario",
          "tuple_id",
          "frame_hex",
          "group_id",
          "payload_len",
          "payload_class",
          "candidate_semantics",
          "fixture_decoder_coverage",
          "payload_variation_observed",
          "risk_class",
          "read_only_probe_allowed",
          "corrected_read_only_probe_ready",
          "semantic_decode_claim",
          "registry_promotion_claim",
          "output_sendability_claim",
          "hardware_output_authorized",
          "native_control_evidence"
        ],
        "properties": {
          "scenario": { "type": "string" },
          "tuple_id": { "type": "string" },
          "frame_hex": { "type": "string" },
          "group_id": { "type": "string" },
          "payload_len": { "type": "integer", "minimum": 0 },
          "payload_class": { "const": "zero_filled" },
          "candidate_semantics": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "fixture_decoder_coverage": { "const": true },
          "payload_variation_observed": { "const": false },
          "risk_class": { "const": "unknown_do_not_send" },
          "read_only_probe_allowed": { "const": false },
          "corrected_read_only_probe_ready": { "const": false },
          "semantic_decode_claim": { "const": false },
          "registry_promotion_claim": { "const": false },
          "output_sendability_claim": { "const": false },
          "hardware_output_authorized": { "const": false },
          "native_control_evidence": { "const": false }
        },
        "additionalProperties": true
      }
    },
    "payload_bearing_authority_state_source_found": { "const": false },
    "reviewed_equivalent_status_source_found": { "const": false },
    "corrected_read_only_probe_ready": { "const": false },
    "live_read_only_probe_allowed": { "const": false },
    "authorization_plan_allowed": { "const": false },
    "motion_attempt_allowed": { "const": false },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "release_ready": { "const": false },
    "registry_promotion_claim": { "const": false },
    "output_sendability_claim": { "const": false },
    "semantic_decode_claim": { "const": false },
    "wheel_moved_under_openracing": { "const": false },
    "visible_motion_verified": { "const": false },
    "output_was_sent": { "const": false },
    "authority_state": { "const": "blocked" },
    "no_hid_device_opened": { "const": true },
    "opened_serial_device": { "const": false },
    "sent_read_only_query_commands": { "const": false },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "mode_enable_candidates_sendable": { "const": false },
    "planned_next_output_allowed": { "const": false },
    "unknown_safety_or_mode_state_blocks_authority": { "const": true },
    "zero_response_diagnosis": { "type": "string" },
    "exact_next_blocker": { "type": "string" },
    "next_allowed_action": { "type": "string" },
    "blocked_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
