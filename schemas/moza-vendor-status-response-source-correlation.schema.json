      "type": "integer",
      "minimum": 1
    },
    "response_payload_tuple_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "response_nonzero_payload_tuple_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "response_correlation_group_count": { "type": "integer", "minimum": 4 },
    "correlated_response_group_count": { "type": "integer", "minimum": 1 },
