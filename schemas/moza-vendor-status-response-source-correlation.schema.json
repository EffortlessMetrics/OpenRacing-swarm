  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": {
      "const": "moza_vendor_status_response_source_correlation"
    },
    "claim_scope": {
      "const": "no_output_authority_status_response_source_correlation"
    },
    "command": {
      "const": "wheelctl moza vendor-status-response-source-correlation"
    },
    "source_gap_receipt": { "type": "string" },
    "endpoint_candidates_receipt": { "type": "string" },
    "protocol_evidence_review_receipt": { "type": "string" },
    "source_gap_validated": { "const": true },
    "source_gap_blocker_before_correlation": { "type": "string" },
    "correlation_scope": {
      "const": "stored_passive_sample_tuple_cooccurrence_only"
    },
    "device_to_host_serial_frame_sample_scope": {
