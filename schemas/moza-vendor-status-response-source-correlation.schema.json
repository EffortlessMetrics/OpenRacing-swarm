    "mode_or_session_response_correlation_found": { "const": true },
    "command_id_0x07_response_correlation_found": { "const": false },
    "response_correlation_groups": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "group_id",
          "source_kind",
          "input_artifact",
          "input_tuple_ids",
          "expected_response_tuple_ids",
          "matched_expected_response_tuple_ids",
          "sample_scoped_response_correlation_found",
          "payload_bearing_authority_state_source_found",
          "reviewed_equivalent_status_source_found",
          "classification",
          "read_only_probe_allowed",
          "corrected_read_only_probe_ready",
          "semantic_decode_claim",
          "registry_promotion_claim",
          "output_sendability_claim",
          "hardware_output_authorized",
          "native_control_evidence",
          "timing_correlation_proven",
          "required_next_review"
        ],
        "properties": {
          "group_id": { "type": "string" },
          "source_kind": { "type": "string" },
          "input_artifact": { "type": "string" },
          "input_tuple_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_response_tuple_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "matched_expected_response_tuple_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sample_scoped_response_correlation_found": { "type": "boolean" },
          "all_expected_response_tuples_observed": { "type": "boolean" },
          "scenario_cooccurrence_count": { "type": "integer", "minimum": 0 },
          "scenario_cooccurrences": {
            "type": "array",
            "items": { "type": "object" }
          },
          "payload_bearing_authority_state_source_found": { "const": false },
          "reviewed_equivalent_status_source_found": { "const": false },
          "classification": { "type": "string" },
          "read_only_probe_allowed": { "const": false },
          "corrected_read_only_probe_ready": { "const": false },
          "semantic_decode_claim": { "const": false },
          "registry_promotion_claim": { "const": false },
          "output_sendability_claim": { "const": false },
          "hardware_output_authorized": { "const": false },
          "native_control_evidence": { "const": false },
          "timing_correlation_proven": { "const": false },
          "required_next_review": { "type": "string" }
        },
        "additionalProperties": true
      },
      "contains": {
        "type": "object",
        "required": [
          "group_id",
          "sample_scoped_response_correlation_found",
          "payload_bearing_authority_state_source_found"
        ],
        "properties": {
          "group_id": { "const": "passive_session_authority_pair_0x5a_0x5d" },
          "sample_scoped_response_correlation_found": { "const": true },
          "payload_bearing_authority_state_source_found": { "const": false }
        }
      }
    },
    "payload_bearing_authority_state_source_found": { "const": false },
    "reviewed_equivalent_status_source_found": { "const": false },
    "corrected_read_only_probe_ready": { "const": false },
    "live_read_only_probe_allowed": { "const": false },
    "authorization_plan_allowed": { "const": false },
    "motion_attempt_allowed": { "const": false },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "release_ready": { "const": false },
    "registry_promotion_claim": { "const": false },
    "output_sendability_claim": { "const": false },
    "semantic_decode_claim": { "const": false },
    "wheel_moved_under_openracing": { "const": false },
    "visible_motion_verified": { "const": false },
    "output_was_sent": { "const": false },
    "authority_state": { "const": "blocked" },
    "no_hid_device_opened": { "const": true },
    "opened_serial_device": { "const": false },
    "sent_read_only_query_commands": { "const": false },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "mode_enable_candidates_sendable": { "const": false },
    "planned_next_output_allowed": { "const": false },
    "unknown_safety_or_mode_state_blocks_authority": { "const": true },
    "exact_next_blocker": { "type": "string" },
    "next_allowed_action": { "type": "string" },
    "blocked_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
