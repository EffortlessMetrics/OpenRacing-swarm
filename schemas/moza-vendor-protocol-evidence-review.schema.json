{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-protocol-evidence-review.schema.json",
  "title": "Moza Vendor Protocol Evidence Review",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "generated_at_utc",
    "lane",
    "sniff_root",
    "command_registry_path",
    "vendor_authority_attempt_receipt",
    "post_authority_response_receipt",
    "evidence_inputs_validated",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "no_hid_device_opened",
    "no_serial_device_opened",
    "no_read_only_query_sent",
    "no_output_reports_sent",
    "no_feature_reports_sent",
    "no_serial_writes_sent",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "protocol_evidence_classification",
    "protocol_evidence_sufficient_for_output_plan",
    "sniff_evidence",
    "command_registry_review",
    "passive_tuple_registry_coverage",
    "post_authority_pidff_result",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "planned_next_output",
    "notes"
  ],
  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": { "const": "moza_vendor_protocol_evidence_review" },
    "claim_scope": { "const": "no_output_protocol_evidence_review" },
    "command": { "const": "wheelctl moza vendor-protocol-evidence-review" },
    "generated_at_utc": { "type": "string" },
    "lane": { "type": "string" },
    "sniff_root": { "type": "string" },
    "command_registry_path": { "type": "string" },
    "vendor_authority_attempt_receipt": { "type": "string" },
    "post_authority_response_receipt": { "type": "string" },
    "evidence_inputs_validated": { "const": true },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "no_hid_device_opened": { "const": true },
    "no_serial_device_opened": { "const": true },
    "no_read_only_query_sent": { "const": true },
    "no_output_reports_sent": { "const": true },
    "no_feature_reports_sent": { "const": true },
    "no_serial_writes_sent": { "const": true },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "protocol_evidence_classification": { "type": "string" },
    "protocol_evidence_sufficient_for_output_plan": { "const": false },
    "sniff_evidence": {
      "type": "object",
      "required": [
        "required_scenario_count",
        "completed_scenario_count",
        "missing_scenario_count",
        "completed_scenarios",
        "missing_scenarios",
        "total_host_to_device_unclassified_packets",
        "total_host_to_device_payload_missing_packets",
        "total_host_to_device_data_len_bytes",
        "total_host_to_device_payload_extracted_packet_count",
        "total_host_to_device_payload_extracted_bytes",
        "total_host_to_device_serial_frame_packet_count",
        "total_host_to_device_serial_frame_count",
        "total_host_to_device_serial_frame_checksum_valid_count",
        "total_host_to_device_serial_frame_checksum_invalid_count",
        "total_host_to_device_serial_frame_commandless_count",
        "host_to_device_serial_frame_tuple_sample_count",
        "host_to_device_decode_gap_detected",
        "host_to_device_payload_export_gap_detected",
        "host_to_device_serial_frame_shape_decode_gap_detected",
        "decode_gap_scenarios",
        "payload_export_gap_scenarios",
        "serial_frame_shape_decode_gap_scenarios",
        "host_to_device_serial_frame_tuple_ids",
        "decode_recommended_by_summaries",
        "passive_summaries_native_control_evidence",
        "scenarios"
      ],
      "properties": {
        "required_scenario_count": { "type": "integer", "minimum": 1 },
        "completed_scenario_count": { "type": "integer", "minimum": 0 },
        "missing_scenario_count": { "type": "integer", "minimum": 0 },
        "completed_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "total_host_to_device_unclassified_packets": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_payload_missing_packets": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_data_len_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_payload_extracted_packet_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_payload_extracted_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_serial_frame_packet_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_serial_frame_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_serial_frame_checksum_valid_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_serial_frame_checksum_invalid_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_host_to_device_serial_frame_commandless_count": {
          "type": "integer",
          "minimum": 0
        },
        "host_to_device_serial_frame_tuple_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "host_to_device_decode_gap_detected": { "type": "boolean" },
        "host_to_device_payload_export_gap_detected": { "type": "boolean" },
        "host_to_device_serial_frame_shape_decode_gap_detected": {
          "type": "boolean"
        },
        "decode_gap_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "payload_export_gap_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "serial_frame_shape_decode_gap_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "host_to_device_serial_frame_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "decode_recommended_by_summaries": { "type": "boolean" },
        "passive_summaries_native_control_evidence": { "const": false },
        "scenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "scenario",
              "status",
              "summary_validated",
              "host_to_device_unclassified_packet_count",
              "host_to_device_decode_gap",
              "host_to_device_payload_missing_packet_count",
              "host_to_device_payload_export_gap",
              "host_to_device_serial_frame_packet_count",
              "host_to_device_serial_frame_count",
              "host_to_device_serial_frame_checksum_valid_count",
              "host_to_device_serial_frame_checksum_invalid_count",
              "host_to_device_serial_frame_commandless_count",
              "host_to_device_serial_frame_shape_decode_gap",
              "host_to_device_serial_frame_tuple_ids",
              "host_to_device_serial_frame_tuple_counts",
              "host_to_device_serial_frame_tuple_samples",
              "native_control_evidence",
              "readiness_claim"
            ],
            "properties": {
              "scenario": { "type": "string" },
              "status": { "type": "string" },
              "summary_validated": { "type": "boolean" },
              "host_to_device_unclassified_packet_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_decode_gap": { "type": "boolean" },
              "host_to_device_payload_missing_packet_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_payload_export_gap": { "type": "boolean" },
              "host_to_device_serial_frame_packet_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_serial_frame_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_serial_frame_checksum_valid_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_serial_frame_checksum_invalid_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_serial_frame_commandless_count": {
                "type": "integer",
                "minimum": 0
              },
              "host_to_device_serial_frame_shape_decode_gap": {
                "type": "boolean"
              },
              "host_to_device_serial_frame_tuple_ids": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "host_to_device_serial_frame_tuple_counts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "tuple_id",
                    "group",
                    "device_id",
                    "payload_len_min",
                    "payload_len_max",
                    "count",
                    "checksum_valid_count",
                    "checksum_invalid_count"
                  ],
                  "properties": {
                    "tuple_id": { "type": "string" },
                    "group": { "type": "string" },
                    "device_id": { "type": "string" },
                    "command": {
                      "type": ["string", "null"]
                    },
                    "payload_len_min": { "type": "integer", "minimum": 0 },
                    "payload_len_max": { "type": "integer", "minimum": 0 },
                    "count": { "type": "integer", "minimum": 0 },
                    "checksum_valid_count": { "type": "integer", "minimum": 0 },
                    "checksum_invalid_count": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "additionalProperties": true
                }
              },
              "host_to_device_serial_frame_tuple_samples": {
                "type": "array",
                "items": { "$ref": "#/$defs/passive_tuple_sample_frame" }
              },
              "native_control_evidence": { "const": false },
              "readiness_claim": { "const": false }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "command_registry_review": {
      "type": "object",
      "required": [
        "registry",
        "registry_completeness",
        "codec_status",
        "command_count",
        "hardware_output_authorized_any"
      ],
      "properties": {
        "registry": { "type": "string" },
        "registry_completeness": { "const": "complete" },
        "codec_status": { "const": "semantic_only" },
        "command_count": { "type": "integer", "minimum": 15 },
        "hardware_output_authorized_any": { "const": false }
      },
      "additionalProperties": true
    },
    "passive_tuple_registry_coverage": {
      "type": "object",
      "required": [
        "review_scope",
        "total_tuple_id_count",
        "known_registry_tuple_count",
        "known_read_only_status_tuple_count",
        "known_write_like_tuple_count",
        "commandless_tuple_count",
        "unknown_commanded_tuple_count",
        "malformed_tuple_count",
        "known_registry_matches",
        "known_registry_tuple_ids",
        "known_read_only_status_tuple_ids",
        "known_write_like_tuple_ids",
        "commandless_tuple_ids",
        "unknown_commanded_tuple_ids",
        "malformed_tuple_ids",
        "tuple_frequency_summary",
        "highest_frequency_tuple_ids",
        "highest_frequency_unknown_commanded_tuple_ids",
        "decode_candidate_sample_scope",
        "decode_candidate_sample_count",
        "decode_candidate_sample_tuple_ids",
        "decode_candidate_sample_fixtures",
        "unknown_tuple_risk_class",
        "protocol_evidence_sufficient_for_output_plan",
        "hardware_output_authorized",
        "native_control_evidence",
        "output_sendability_claim",
        "notes"
      ],
      "properties": {
        "review_scope": {
          "const": "checked_in_passive_tuple_ids_vs_semantic_registry"
        },
        "total_tuple_id_count": { "type": "integer", "minimum": 0 },
        "known_registry_tuple_count": { "type": "integer", "minimum": 0 },
        "known_read_only_status_tuple_count": {
          "type": "integer",
          "minimum": 0
        },
        "known_write_like_tuple_count": { "type": "integer", "minimum": 0 },
        "commandless_tuple_count": { "type": "integer", "minimum": 0 },
        "unknown_commanded_tuple_count": { "type": "integer", "minimum": 0 },
        "malformed_tuple_count": { "type": "integer", "minimum": 0 },
        "known_registry_matches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tuple_id",
              "command_id",
              "family",
              "risk_class",
              "read_only_status_probe_allowed",
              "hardware_output_authorized",
              "output_sendability_claim"
            ],
            "properties": {
              "tuple_id": { "type": "string" },
              "command_id": { "type": "string" },
              "family": { "type": "string" },
              "risk_class": { "type": "string" },
              "read_only_status_probe_allowed": { "type": "boolean" },
              "hardware_output_authorized": { "const": false },
              "output_sendability_claim": { "const": false }
            },
            "additionalProperties": true
          }
        },
        "known_registry_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "known_read_only_status_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "known_write_like_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "commandless_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "unknown_commanded_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "malformed_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "tuple_frequency_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tuple_id",
              "registry_status",
              "total_count",
              "checksum_valid_count",
              "checksum_invalid_count",
              "payload_len_min",
              "payload_len_max",
              "scenario_count",
              "scenarios",
              "hardware_output_authorized",
              "output_sendability_claim"
            ],
            "properties": {
              "tuple_id": { "type": "string" },
              "registry_status": { "type": "string" },
              "total_count": { "type": "integer", "minimum": 0 },
              "checksum_valid_count": { "type": "integer", "minimum": 0 },
              "checksum_invalid_count": { "type": "integer", "minimum": 0 },
              "payload_len_min": { "type": "integer", "minimum": 0 },
              "payload_len_max": { "type": "integer", "minimum": 0 },
              "scenario_count": { "type": "integer", "minimum": 0 },
              "scenarios": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "scenario",
                    "count",
                    "checksum_valid_count",
                    "checksum_invalid_count",
                    "payload_len_min",
                    "payload_len_max"
                  ],
                  "properties": {
                    "scenario": { "type": "string" },
                    "count": { "type": "integer", "minimum": 0 },
                    "checksum_valid_count": { "type": "integer", "minimum": 0 },
                    "checksum_invalid_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "payload_len_min": { "type": "integer", "minimum": 0 },
                    "payload_len_max": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": true
                }
              },
              "hardware_output_authorized": { "const": false },
              "output_sendability_claim": { "const": false }
            },
            "additionalProperties": true
          }
        },
        "highest_frequency_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "highest_frequency_unknown_commanded_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "decode_candidate_sample_scope": {
          "const": "highest_frequency_unknown_commanded_tuples"
        },
        "decode_candidate_sample_count": { "type": "integer", "minimum": 0 },
        "decode_candidate_sample_tuple_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "decode_candidate_sample_fixtures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tuple_id",
              "registry_status",
              "total_count",
              "sample_count",
              "sample_frames",
              "hardware_output_authorized",
              "output_sendability_claim"
            ],
            "properties": {
              "tuple_id": { "type": "string" },
              "registry_status": { "const": "unknown_commanded" },
              "total_count": { "type": "integer", "minimum": 0 },
              "sample_count": { "type": "integer", "minimum": 0 },
              "sample_frames": {
                "type": "array",
                "items": { "$ref": "#/$defs/passive_tuple_sample_frame" }
              },
              "hardware_output_authorized": { "const": false },
              "output_sendability_claim": { "const": false }
            },
            "additionalProperties": true
          }
        },
        "unknown_tuple_risk_class": { "const": "unknown_do_not_send" },
        "protocol_evidence_sufficient_for_output_plan": { "const": false },
        "hardware_output_authorized": { "const": false },
        "native_control_evidence": { "const": false },
        "output_sendability_claim": { "const": false },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "post_authority_pidff_result": {
      "type": "object",
      "required": [
        "tested_command_id",
        "classification",
        "visible_motion_candidate",
        "response_regressed",
        "eliminated_hypothesis"
      ],
      "properties": {
        "tested_command_id": { "type": "string" },
        "classification": { "type": "string" },
        "visible_motion_candidate": { "const": false },
        "response_regressed": { "type": "boolean" },
        "eliminated_hypothesis": { "type": "string" }
      },
      "additionalProperties": true
    },
    "next_allowed_action": { "type": "string" },
    "blocked_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "planned_next_output": {
      "type": "object",
      "required": ["allowed", "reason"],
      "properties": {
        "allowed": { "const": false },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "passive_tuple_sample_frame": {
      "type": "object",
      "required": [
        "scenario",
        "tuple_id",
        "group",
        "device_id",
        "command",
        "sample_index",
        "packet_ordinal",
        "frame_ordinal_in_packet",
        "frame_hex",
        "declared_len",
        "payload_len",
        "payload_hex",
        "checksum_hex",
        "checksum_valid",
        "hardware_output_authorized",
        "output_sendability_claim"
      ],
      "properties": {
        "scenario": { "type": "string" },
        "tuple_id": { "type": "string" },
        "group": { "type": "string" },
        "device_id": { "type": "string" },
        "command": { "type": ["string", "null"] },
        "sample_index": { "type": "integer", "minimum": 1 },
        "packet_ordinal": { "type": "integer", "minimum": 1 },
        "frame_ordinal_in_packet": { "type": "integer", "minimum": 1 },
        "frame_hex": { "$ref": "#/$defs/hex_bytes_compact" },
        "declared_len": { "type": "integer", "minimum": 0 },
        "payload_len": { "type": "integer", "minimum": 0 },
        "payload_hex": { "$ref": "#/$defs/hex_bytes_compact_or_empty" },
        "checksum_hex": {
          "type": "string",
          "pattern": "^0x[0-9A-Fa-f]{2}$"
        },
        "checksum_valid": { "const": true },
        "hardware_output_authorized": { "const": false },
        "output_sendability_claim": { "const": false }
      },
      "additionalProperties": true
    },
    "hex_bytes_compact": {
      "type": "string",
      "pattern": "^([0-9A-Fa-f]{2})+$"
    },
    "hex_bytes_compact_or_empty": {
      "type": "string",
      "pattern": "^([0-9A-Fa-f]{2})*$"
    }
  }
}
