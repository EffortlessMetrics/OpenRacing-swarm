{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-post-authority-pidff-response.schema.json",
  "title": "Moza vendor post-authority PIDFF response comparison receipt",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "generated_at_utc",
    "vendor_authority_attempt_receipt",
    "baseline_response_receipt",
    "post_authority_response_receipt",
    "vendor_authority_attempt_validated",
    "baseline_response_validated",
    "post_authority_response_validated",
    "comparable_pidff_profile",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "no_hid_device_opened",
    "no_serial_device_opened",
    "no_read_only_query_sent",
    "no_output_reports_sent",
    "no_feature_reports_sent",
    "no_serial_writes_sent",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "comparison",
    "baseline_response",
    "post_authority_response",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "planned_next_output"
  ],
  "properties": {
    "success": {"const": true},
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_post_authority_pidff_response"},
    "claim_scope": {"const": "post_authority_pidff_response_comparison_only"},
    "command": {"const": "wheelctl moza vendor-post-authority-pidff-response"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "vendor_authority_attempt_receipt": {"type": "string", "minLength": 1},
    "baseline_response_receipt": {"type": "string", "minLength": 1},
    "post_authority_response_receipt": {"type": "string", "minLength": 1},
    "vendor_authority_attempt_validated": {"const": true},
    "baseline_response_validated": {"const": true},
    "post_authority_response_validated": {"const": true},
    "comparable_pidff_profile": {"const": true},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": false},
    "native_visible_ready": {"const": false},
    "smoke_ready": {"const": false},
    "no_hid_device_opened": {"const": true},
    "no_serial_device_opened": {"const": true},
    "no_read_only_query_sent": {"const": true},
    "no_output_reports_sent": {"const": true},
    "no_feature_reports_sent": {"const": true},
    "no_serial_writes_sent": {"const": true},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "high_torque_enabled": {"const": false},
    "comparison": {
      "type": "object",
      "required": [
        "classification",
        "response_threshold_degrees",
        "movement_threshold_degrees",
        "baseline_angle_delta_degrees",
        "post_authority_angle_delta_degrees",
        "delta_change_degrees",
        "absolute_delta_change_degrees",
        "baseline_movement_observed",
        "post_authority_movement_observed",
        "visible_motion_candidate",
        "response_increased",
        "response_regressed"
      ],
      "properties": {
        "classification": {
          "enum": [
            "post_authority_visible_motion_candidate_requires_verifier",
            "post_authority_pidff_response_increased_no_motion_claim",
            "post_authority_pidff_response_unchanged",
            "post_authority_pidff_response_regressed"
          ]
        },
        "response_threshold_degrees": {"type": "number", "minimum": 0},
        "movement_threshold_degrees": {"type": "number", "minimum": 0},
        "baseline_angle_delta_degrees": {"type": "number"},
        "post_authority_angle_delta_degrees": {"type": "number"},
        "delta_change_degrees": {"type": "number"},
        "absolute_delta_change_degrees": {"type": "number", "minimum": 0},
        "baseline_movement_observed": {"type": "boolean"},
        "post_authority_movement_observed": {"type": "boolean"},
        "visible_motion_candidate": {"type": "boolean"},
        "response_increased": {"type": "boolean"},
        "response_regressed": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "baseline_response": {"$ref": "#/$defs/native_pidff_response"},
    "post_authority_response": {"$ref": "#/$defs/native_pidff_response"},
    "next_allowed_action": {"type": "string", "minLength": 1},
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "planned_next_output": {
      "type": "object",
      "required": ["allowed", "reason"],
      "properties": {
        "allowed": {"const": false},
        "reason": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "native_pidff_response": {
      "type": "object",
      "required": [
        "receipt",
        "generated_at_utc",
        "selector",
        "profile",
        "output_strategy",
        "max_percent",
        "duration_ms",
        "movement_threshold_degrees",
        "angle_delta_degrees",
        "movement_observed",
        "write_attempts",
        "writes_ok",
        "write_errors",
        "final_zero_sent",
        "final_stop_all_sent",
        "post_stop_stable",
        "no_direct_torque_reports",
        "no_high_torque"
      ],
      "properties": {
        "receipt": {"type": "string", "minLength": 1},
        "generated_at_utc": {"type": "string", "minLength": 1},
        "selector": {"type": "string", "minLength": 1},
        "profile": {"type": "string", "minLength": 1},
        "output_strategy": {"type": "string", "minLength": 1},
        "max_percent": {"type": "number", "exclusiveMinimum": 0},
        "duration_ms": {"type": "integer", "minimum": 1},
        "movement_threshold_degrees": {"type": "number", "exclusiveMinimum": 0},
        "angle_delta_degrees": {"type": "number"},
        "movement_observed": {"type": "boolean"},
        "write_attempts": {"type": "integer", "minimum": 1},
        "writes_ok": {"type": "integer", "minimum": 1},
        "write_errors": {"const": 0},
        "final_zero_sent": {"const": true},
        "final_stop_all_sent": {"const": true},
        "post_stop_stable": {"const": true},
        "no_direct_torque_reports": {"const": true},
        "no_high_torque": {"const": true}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
