{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-timing-correlation-plan.schema.json",
  "title": "Moza R5 0x8E timing-correlation capture plan",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "semantic_review_receipt",
    "target_group_id",
    "target_tuple_ids",
    "target_samples",
    "planned_capture_scenario",
    "capture_command_templates",
    "capture_recorded",
    "timing_correlation_proven",
    "payload_bearing_authority_state_source_found",
    "live_read_only_probe_allowed",
    "authorization_plan_allowed",
    "motion_attempt_allowed",
    "hardware_output_authorized",
    "native_control_evidence",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": {
      "const": "moza_vendor_status_timing_correlation_plan"
    },
    "claim_scope": {
      "const": "no_output_0x8e_timing_correlation_capture_plan"
    },
    "command": {
      "const": "wheelctl moza vendor-status-timing-correlation-plan"
    },
    "target_group_id": {
      "const": "passive_payload_bearing_status_source_0x8e"
    },
    "target_tuple_ids": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "0x8E/0x21/0x00" } },
        { "contains": { "const": "0x8E/0x31/0x00" } },
        { "contains": { "const": "0x8E/0x71/0x00" } },
        { "contains": { "const": "0x8E/0x91/0x00" } }
      ]
    },
    "target_samples": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "tuple_id",
          "payload_hex",
          "required_correlation",
          "risk_class",
          "semantic_decode_claim",
          "registry_promotion_claim",
          "output_sendability_claim",
          "read_only_probe_allowed",
          "hardware_output_authorized",
          "native_control_evidence"
        ],
        "properties": {
          "tuple_id": {
            "enum": [
              "0x8E/0x21/0x00",
              "0x8E/0x31/0x00",
              "0x8E/0x71/0x00",
              "0x8E/0x91/0x00"
            ]
          },
          "payload_hex": { "type": "string", "minLength": 1 },
          "required_correlation": {
            "const": "packet timestamp near a named operator event marker"
          },
          "risk_class": { "const": "unknown_do_not_send" },
          "semantic_decode_claim": { "const": false },
          "registry_promotion_claim": { "const": false },
          "output_sendability_claim": { "const": false },
          "read_only_probe_allowed": { "const": false },
          "hardware_output_authorized": { "const": false },
          "native_control_evidence": { "const": false }
        }
      }
    },
    "planned_capture_scenario": {
      "const": "pit-house-0x8e-timing-correlation"
    },
    "planned_capture_kind": {
      "const": "passive_external_usb_observation"
    },
    "capture_command_templates": {
      "type": "array",
      "minItems": 8,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "materializes_capture_command",
              "materializes_event_marker_commands",
              "materialized_command_in",
              "selector_source"
            ],
            "properties": {
              "name": { "const": "render_checked_in_operator_notes_template" },
              "output_enabled": { "const": false },
              "materializes_capture_command": { "const": true },
              "materializes_event_marker_commands": { "const": true },
              "materialized_command_in": {
                "const": "target/sniff/pit-house-0x8e-timing-correlation/operator-notes.md"
              },
              "selector_source": {
                "const": "fresh hardware doctor Moza USBPcap hint"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "edits_operator_notes_only",
              "requires_capture_running",
              "command_example_marker",
              "all_marker_commands_materialized_in",
              "marker_command_source"
            ],
            "properties": {
              "name": { "const": "stamp_operator_event_markers" },
              "output_enabled": { "const": false },
              "edits_operator_notes_only": { "const": true },
              "requires_capture_running": { "const": true },
              "command_example_marker": { "const": "capture_start_utc" },
              "all_marker_commands_materialized_in": {
                "const": "target/sniff/pit-house-0x8e-timing-correlation/operator-notes.md"
              },
              "marker_command_source": {
                "const": "target/sniff/pit-house-0x8e-timing-correlation/operator-notes.md"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "command_has_selector_placeholders",
              "must_not_run_unrendered_template",
              "concrete_command_source",
              "selector_source"
            ],
            "properties": {
              "name": { "const": "run_bounded_passive_usbpcap_capture" },
              "output_enabled": { "const": false },
              "openracing_hardware_output": { "const": false },
              "command_has_selector_placeholders": { "const": true },
              "must_not_run_unrendered_template": { "const": true },
              "concrete_command_source": {
                "const": "target/sniff/pit-house-0x8e-timing-correlation/operator-notes.md"
              },
              "selector_source": {
                "const": "fresh hardware doctor Moza USBPcap hint rendered by sniff-notes-template"
              }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "requires_operator_notes",
              "raw_pcapng_commit_default"
            ],
            "properties": {
              "name": { "const": "record_passive_sniff_receipt" },
              "output_enabled": { "const": false },
              "requires_operator_notes": { "const": true },
              "raw_pcapng_commit_default": { "const": false }
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "requires_operator_notes",
              "raw_pcapng_commit_default"
            ],
            "properties": {
              "name": { "const": "bundle_passive_sniff_evidence" },
              "output_enabled": { "const": false },
              "requires_operator_notes": { "const": true },
              "raw_pcapng_commit_default": { "const": false }
            }
          }
        }
      ]
    },
    "planned_capture_duration_ms": {
      "type": "integer",
      "minimum": 60000
    },
    "raw_pcap_commit_default": { "const": false },
    "capture_recorded": { "const": false },
    "timing_correlation_proven": { "const": false },
    "same_tuple_payload_variation_required": { "const": true },
    "operator_event_markers_required": { "const": true },
    "payload_bearing_authority_state_source_found": { "const": false },
    "reviewed_equivalent_status_source_found": { "const": false },
    "corrected_read_only_probe_ready": { "const": false },
    "live_read_only_probe_allowed": { "const": false },
    "authorization_plan_allowed": { "const": false },
    "motion_attempt_allowed": { "const": false },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "release_ready": { "const": false },
    "registry_promotion_claim": { "const": false },
    "output_sendability_claim": { "const": false },
    "semantic_decode_claim": { "const": false },
    "wheel_moved_under_openracing": { "const": false },
    "visible_motion_verified": { "const": false },
    "output_was_sent": { "const": false },
    "authority_state": { "const": "blocked" },
    "no_hid_device_opened": { "const": true },
    "opened_serial_device": { "const": false },
    "sent_read_only_query_commands": { "const": false },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "mode_enable_candidates_sendable": { "const": false },
    "planned_next_output_allowed": { "const": false },
    "unknown_safety_or_mode_state_blocks_authority": { "const": true },
    "blocked_actions": {
      "type": "array",
      "contains": { "const": "hardware writes" }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1
    }
  }
}
