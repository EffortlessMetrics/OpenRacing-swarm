{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-mode-matrix-plan.schema.json",
  "title": "Moza Vendor Read-Only Status Mode Matrix Plan",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "staged_only",
    "live_hardware_access_performed",
    "opened_hid_device",
    "opened_serial_device",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "matrix_required_before_authority",
    "unknown_safety_or_mode_state_blocks_authority",
    "planned_next_output_allowed",
    "allowed_read_only_command_ids",
    "blocked_mode_enable_candidate_groups",
    "expected_fields"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_status_mode_matrix_plan"},
    "claim_scope": {"const": "staged_read_only_status_mode_matrix_only"},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": false},
    "native_visible_ready": {"const": false},
    "smoke_ready": {"const": false},
    "release_ready": {"const": false},
    "registry_promotion_claim": {"const": false},
    "output_sendability_claim": {"const": false},
    "next_allowed_action": {"type": "string"},
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "staged_only": {"const": true},
    "live_hardware_access_performed": {"const": false},
    "opened_hid_device": {"const": false},
    "opened_serial_device": {"const": false},
    "sent_read_only_query_commands": {"const": false},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "high_torque_enabled": {"const": false},
    "matrix_required_before_authority": {"const": true},
    "unknown_safety_or_mode_state_blocks_authority": {"const": true},
    "planned_next_output_allowed": {"const": false},
    "allowed_read_only_command_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "blocked_mode_enable_candidate_groups": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "tuple_ids",
          "risk_class",
          "sendable",
          "registry_promotion_claim",
          "output_sendability_claim"
        ],
        "properties": {
          "candidate_id": {"type": "string"},
          "tuple_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "risk_class": {"const": "unknown_do_not_send"},
          "sendable": {"const": false},
          "registry_promotion_claim": {"const": false},
          "output_sendability_claim": {"const": false}
        },
        "additionalProperties": true
      }
    },
    "expected_fields": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object"}
    }
  },
  "additionalProperties": true
}
