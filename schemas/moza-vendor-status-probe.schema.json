{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-probe.schema.json",
  "title": "Moza Vendor Read-Only Status Probe Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts",
    "no_hid_device_opened",
    "opened_serial_device",
    "serial_identity_verified",
    "no_ffb_writes",
    "no_output_reports",
    "no_feature_reports",
    "no_serial_config_commands",
    "no_firmware_or_dfu_commands",
    "high_torque_enabled",
    "sent_read_only_query_commands",
    "sent_read_only_query_count",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "mode_enable_candidates_sendable",
    "status_mode_matrix_stage",
    "status_mode_matrix_plan",
    "unknown_safety_or_mode_state_blocks_authority",
    "planned_next_output_allowed",
    "real_hardware_status_evidence",
    "transport_kind",
    "codec_status",
    "hardware_write_eligible",
    "selected_command_count",
    "decoded_response_count",
    "failed_response_count",
    "responses"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "moza_vendor_status_probe"},
    "claim_scope": {"const": "read_only_hardware"},
    "native_control_evidence": {"const": false},
    "hardware_output_authorized": {"const": false},
    "native_visible_ready": {"const": false},
    "smoke_ready": {"const": false},
    "release_ready": {"const": false},
    "registry_promotion_claim": {"const": false},
    "output_sendability_claim": {"const": false},
    "next_allowed_action": {"type": "string"},
    "blocked_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "no_hid_device_opened": {"const": true},
    "opened_serial_device": {"const": true},
    "serial_identity_verified": {"const": true},
    "no_ffb_writes": {"const": true},
    "no_output_reports": {"const": true},
    "no_feature_reports": {"const": true},
    "no_serial_config_commands": {"const": true},
    "no_firmware_or_dfu_commands": {"const": true},
    "high_torque_enabled": {"const": false},
    "sent_read_only_query_commands": {"const": true},
    "sent_read_only_query_count": {"type": "integer", "minimum": 1},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "mode_enable_candidates_sendable": {"const": false},
    "status_mode_matrix_stage": {"const": "read_only_status_probe"},
    "status_mode_matrix_plan": {"const": "ci/hardware/moza-r5/2026-05-13/vendor-status-mode-matrix-plan.json"},
    "unknown_safety_or_mode_state_blocks_authority": {"const": true},
    "planned_next_output_allowed": {"const": false},
    "real_hardware_status_evidence": {"type": "boolean"},
    "transport_kind": {"const": "serial_read_only"},
    "codec_status": {"const": "round_trip_verified"},
    "hardware_write_eligible": {"const": false},
    "response_scan_strategy": {"const": "bounded_stream_demux"},
    "response_scan_max_frames_per_query": {"type": "integer", "minimum": 1, "maximum": 128},
    "scanned_response_frame_count": {"type": "integer", "minimum": 0},
    "skipped_response_frame_count": {"type": "integer", "minimum": 0},
    "skipped_diagnostic_frame_count": {"type": "integer", "minimum": 0},
    "skipped_malformed_or_desynchronized_frame_count": {"type": "integer", "minimum": 0},
    "skipped_non_matching_registry_frame_count": {"type": "integer", "minimum": 0},
    "skipped_unknown_non_registry_frame_count": {"type": "integer", "minimum": 0},
    "selected_command_count": {"type": "integer", "minimum": 1},
    "decoded_response_count": {"type": "integer", "minimum": 0},
    "failed_response_count": {"type": "integer", "minimum": 0},
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "command_name",
          "group",
          "device_id",
          "command",
          "risk_class",
          "query_frame_hex",
          "decoded"
        ],
        "properties": {
          "command_id": {"type": "string"},
          "command_name": {"type": "string"},
          "group": {"type": "integer", "minimum": 0, "maximum": 255},
          "device_id": {"type": "integer", "minimum": 0, "maximum": 255},
          "command": {"type": "integer", "minimum": 0, "maximum": 255},
          "risk_class": {"const": "vendor_status"},
          "query_frame_hex": {"type": "string"},
          "response_scan_stop_reason": {"type": "string"},
          "scanned_response_frame_count": {"type": "integer", "minimum": 0},
          "skipped_response_frame_count": {"type": "integer", "minimum": 0},
          "skipped_diagnostic_frame_count": {"type": "integer", "minimum": 0},
          "skipped_malformed_or_desynchronized_frame_count": {"type": "integer", "minimum": 0},
          "skipped_non_matching_registry_frame_count": {"type": "integer", "minimum": 0},
          "skipped_unknown_non_registry_frame_count": {"type": "integer", "minimum": 0},
          "scanned_response_frames": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "frame_hex",
                "disposition",
                "response_classification",
                "matched_expected_command"
              ],
              "properties": {
                "frame_hex": {"type": "string"},
                "disposition": {
                  "enum": [
                    "matching_registry_status_response",
                    "non_matching_registry_status_response",
                    "skippable_diagnostic_frame",
                    "malformed_or_desynchronized_frame",
                    "unknown_non_registry_frame"
                  ]
                },
                "response_classification": {"type": "string"},
                "observed_tuple_id": {"type": "string"},
                "matched_expected_command": {"type": "boolean"},
                "checksum_valid": {"type": "boolean"},
                "error": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "decoded": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
