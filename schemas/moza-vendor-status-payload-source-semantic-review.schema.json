{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-payload-source-semantic-review.schema.json",
  "title": "Moza R5 payload-source semantic review receipt",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "payload_source_candidates_receipt",
    "fixture_review_scope",
    "fixture_decoder_group_id",
    "reviewed_payload_candidate_count",
    "reviewed_payload_source_samples",
    "same_tuple_payload_variation_observed",
    "cross_tuple_payload_diversity_observed",
    "only_setting_change_scenario_observed",
    "semantic_review_verdict",
    "authority_state_source_verdict",
    "payload_bearing_authority_state_source_found",
    "reviewed_equivalent_status_source_found",
    "corrected_read_only_probe_ready",
    "live_read_only_probe_allowed",
    "authorization_plan_allowed",
    "motion_attempt_allowed",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "semantic_decode_claim",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "no_hid_device_opened",
    "opened_serial_device",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "mode_enable_candidates_sendable",
    "planned_next_output_allowed",
    "unknown_safety_or_mode_state_blocks_authority",
    "exact_next_blocker",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": {
      "const": true
    },
    "schema_version": {
      "const": 1
    },
    "artifact_kind": {
      "const": "moza_vendor_status_payload_source_semantic_review"
    },
    "claim_scope": {
      "const": "no_output_fixture_backed_payload_source_semantic_review"
    },
    "command": {
      "const": "wheelctl moza vendor-status-payload-source-semantic-review"
    },
    "payload_source_candidates_receipt": {
      "type": "string"
    },
    "fixture_review_scope": {
      "const": "stored_passive_0x8e_samples_only"
    },
    "fixture_decoder_group_id": {
      "const": "passive_payload_bearing_status_source_0x8e"
    },
    "reviewed_payload_candidate_count": {
      "type": "integer",
      "minimum": 1
    },
    "reviewed_tuple_ids": {
      "type": "array",
      "items": {
        "enum": [
          "0x8E/0x21/0x00",
          "0x8E/0x31/0x00",
          "0x8E/0x71/0x00",
          "0x8E/0x91/0x00"
        ]
      }
    },
    "reviewed_payload_source_samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "tuple_id",
          "frame_hex",
          "group_id",
          "payload_hex",
          "payload_len",
          "payload_class",
          "fixture_decoder_coverage",
          "semantic_review_verdict",
          "authority_state_source_verdict",
          "risk_class",
          "read_only_probe_allowed",
          "corrected_read_only_probe_ready",
          "semantic_decode_claim",
          "registry_promotion_claim",
          "output_sendability_claim",
          "hardware_output_authorized",
          "native_control_evidence"
        ],
        "properties": {
          "tuple_id": {
            "enum": [
              "0x8E/0x21/0x00",
              "0x8E/0x31/0x00",
              "0x8E/0x71/0x00",
              "0x8E/0x91/0x00"
            ]
          },
          "group_id": {
            "const": "passive_payload_bearing_status_source_0x8e"
          },
          "payload_class": {
            "const": "nonzero"
          },
          "payload_len": {
            "const": 6
          },
          "fixture_decoder_coverage": {
            "const": true
          },
          "semantic_review_verdict": {
            "const": "payload_bearing_status_source_question_not_authority_source"
          },
          "authority_state_source_verdict": {
            "const": "insufficient_evidence_no_same_tuple_variation_or_timing_correlation"
          },
          "risk_class": {
            "const": "unknown_do_not_send"
          },
          "read_only_probe_allowed": {
            "const": false
          },
          "corrected_read_only_probe_ready": {
            "const": false
          },
          "semantic_decode_claim": {
            "const": false
          },
          "registry_promotion_claim": {
            "const": false
          },
          "output_sendability_claim": {
            "const": false
          },
          "hardware_output_authorized": {
            "const": false
          },
          "native_control_evidence": {
            "const": false
          }
        }
      }
    },
    "same_tuple_payload_variation_observed": {
      "const": false
    },
    "cross_tuple_payload_diversity_observed": {
      "const": true
    },
    "only_setting_change_scenario_observed": {
      "const": true
    },
    "semantic_review_verdict": {
      "const": "insufficient_for_authority_source"
    },
    "authority_state_source_verdict": {
      "const": "blocked_missing_same_tuple_payload_variation_or_timing_correlation"
    },
    "payload_bearing_authority_state_source_found": {
      "const": false
    },
    "reviewed_equivalent_status_source_found": {
      "const": false
    },
    "corrected_read_only_probe_ready": {
      "const": false
    },
    "live_read_only_probe_allowed": {
      "const": false
    },
    "authorization_plan_allowed": {
      "const": false
    },
    "motion_attempt_allowed": {
      "const": false
    },
    "native_control_evidence": {
      "const": false
    },
    "hardware_output_authorized": {
      "const": false
    },
    "native_visible_ready": {
      "const": false
    },
    "smoke_ready": {
      "const": false
    },
    "release_ready": {
      "const": false
    },
    "registry_promotion_claim": {
      "const": false
    },
    "output_sendability_claim": {
      "const": false
    },
    "semantic_decode_claim": {
      "const": false
    },
    "wheel_moved_under_openracing": {
      "const": false
    },
    "visible_motion_verified": {
      "const": false
    },
    "output_was_sent": {
      "const": false
    },
    "authority_state": {
      "const": "blocked"
    },
    "no_hid_device_opened": {
      "const": true
    },
    "opened_serial_device": {
      "const": false
    },
    "sent_read_only_query_commands": {
      "const": false
    },
    "sent_output_writes": {
      "const": false
    },
    "sent_configuration_writes": {
      "const": false
    },
    "sent_firmware_or_dfu_commands": {
      "const": false
    },
    "high_torque_enabled": {
      "const": false
    },
    "mode_enable_candidates_sendable": {
      "const": false
    },
    "planned_next_output_allowed": {
      "const": false
    },
    "unknown_safety_or_mode_state_blocks_authority": {
      "const": true
    },
    "exact_next_blocker": {
      "type": "string",
      "minLength": 1
    },
    "next_allowed_action": {
      "type": "string",
      "minLength": 1
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
