    "fake_transport_verified": {"const": true},
    "codec_status": {"const": "round_trip_verified"},
    "opened_serial_device": {"const": false},
    "sent_read_only_query_commands": {"const": false},
    "sent_output_writes": {"const": false},
    "sent_configuration_writes": {"const": false},
    "sent_firmware_or_dfu_commands": {"const": false},
    "real_hardware_validated": {"const": false},
    "accepted_fixture_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "blocked_fixture_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
