{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openracing.dev/schemas/moza-vendor-status-payload-source-candidates.schema.json",
  "title": "Moza Vendor Status Payload Source Candidates",
  "type": "object",
  "required": [
    "success",
    "schema_version",
    "artifact_kind",
    "claim_scope",
    "command",
    "response_semantic_fixtures_receipt",
    "protocol_evidence_review_receipt",
    "prior_correlated_response_payload_variation_observed",
    "prior_correlated_payloads_zero_filled",
    "device_to_host_serial_frame_sample_scope",
    "payload_bearing_device_to_host_sample_count",
    "payload_bearing_status_source_candidate_count",
    "payload_bearing_tuple_ids",
    "payload_bearing_group_ids",
    "payload_bearing_scenarios",
    "device_status_response_candidate_tuple_ids",
    "setting_change_payload_bearing_tuple_ids",
    "same_tuple_payload_variation_observed",
    "cross_tuple_payload_diversity_observed",
    "payload_bearing_candidates",
    "all_candidates_unknown_do_not_send",
    "payload_bearing_authority_state_source_found",
    "reviewed_equivalent_status_source_found",
    "corrected_read_only_probe_ready",
    "live_read_only_probe_allowed",
    "authorization_plan_allowed",
    "motion_attempt_allowed",
    "native_control_evidence",
    "hardware_output_authorized",
    "native_visible_ready",
    "smoke_ready",
    "release_ready",
    "registry_promotion_claim",
    "output_sendability_claim",
    "semantic_decode_claim",
    "wheel_moved_under_openracing",
    "visible_motion_verified",
    "output_was_sent",
    "authority_state",
    "no_hid_device_opened",
    "opened_serial_device",
    "sent_read_only_query_commands",
    "sent_output_writes",
    "sent_configuration_writes",
    "sent_firmware_or_dfu_commands",
    "high_torque_enabled",
    "mode_enable_candidates_sendable",
    "planned_next_output_allowed",
    "unknown_safety_or_mode_state_blocks_authority",
    "exact_next_blocker",
    "next_allowed_action",
    "blocked_actions",
    "required_artifacts"
  ],
  "properties": {
    "success": { "const": true },
    "schema_version": { "const": 1 },
    "artifact_kind": {
      "const": "moza_vendor_status_payload_source_candidates"
    },
    "claim_scope": {
      "const": "no_output_payload_bearing_status_source_candidate_review"
    },
    "command": {
      "const": "wheelctl moza vendor-status-payload-source-candidates"
    },
    "response_semantic_fixtures_receipt": { "type": "string" },
    "protocol_evidence_review_receipt": { "type": "string" },
    "prior_correlated_response_payload_variation_observed": { "const": false },
    "prior_correlated_payloads_zero_filled": { "const": true },
    "device_to_host_serial_frame_sample_scope": {
      "const": "observed_report_payload_hex_samples_only"
    },
    "payload_bearing_device_to_host_sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "payload_bearing_status_source_candidate_count": {
      "type": "integer",
      "minimum": 1
    },
    "payload_bearing_tuple_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "contains": { "const": "0x8E/0x91/0x00" }
    },
    "payload_bearing_group_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "contains": { "const": "0x8E" }
    },
    "payload_bearing_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "contains": { "const": "pit-house-setting-change" }
    },
    "device_status_response_candidate_tuple_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "contains": { "const": "0x8E/0x21/0x00" }
    },
    "setting_change_payload_bearing_tuple_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "same_tuple_payload_variation_observed": { "const": false },
    "cross_tuple_payload_diversity_observed": { "const": true },
    "payload_bearing_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scenario",
          "tuple_id",
          "group",
          "device_id",
          "command_id",
          "frame_hex",
          "payload_hex",
          "payload_len",
          "payload_class",
          "candidate_semantics",
          "source_scope",
          "risk_class",
          "semantic_decode_claim",
          "registry_promotion_claim",
          "output_sendability_claim",
          "read_only_probe_allowed",
          "corrected_read_only_probe_ready",
          "payload_bearing_authority_state_source_found",
          "hardware_output_authorized",
          "native_control_evidence"
        ],
        "properties": {
          "scenario": { "type": "string" },
          "tuple_id": { "type": "string" },
          "group": { "type": "string" },
          "device_id": { "type": "string" },
          "command_id": { "type": "string" },
          "frame_hex": { "type": "string" },
          "payload_hex": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "^0+$" }
          },
          "payload_len": { "type": "integer", "minimum": 1 },
          "payload_class": { "const": "nonzero" },
          "candidate_semantics": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_scope": {
            "const": "stored_passive_device_to_host_sample_only"
          },
          "risk_class": { "const": "unknown_do_not_send" },
          "semantic_decode_claim": { "const": false },
          "registry_promotion_claim": { "const": false },
          "output_sendability_claim": { "const": false },
          "read_only_probe_allowed": { "const": false },
          "corrected_read_only_probe_ready": { "const": false },
          "payload_bearing_authority_state_source_found": { "const": false },
          "hardware_output_authorized": { "const": false },
          "native_control_evidence": { "const": false }
        },
        "additionalProperties": true
      }
    },
    "all_candidates_unknown_do_not_send": { "const": true },
    "payload_bearing_authority_state_source_found": { "const": false },
    "reviewed_equivalent_status_source_found": { "const": false },
    "corrected_read_only_probe_ready": { "const": false },
    "live_read_only_probe_allowed": { "const": false },
    "authorization_plan_allowed": { "const": false },
    "motion_attempt_allowed": { "const": false },
    "native_control_evidence": { "const": false },
    "hardware_output_authorized": { "const": false },
    "native_visible_ready": { "const": false },
    "smoke_ready": { "const": false },
    "release_ready": { "const": false },
    "registry_promotion_claim": { "const": false },
    "output_sendability_claim": { "const": false },
    "semantic_decode_claim": { "const": false },
    "wheel_moved_under_openracing": { "const": false },
    "visible_motion_verified": { "const": false },
    "output_was_sent": { "const": false },
    "authority_state": { "const": "blocked" },
    "no_hid_device_opened": { "const": true },
    "opened_serial_device": { "const": false },
    "sent_read_only_query_commands": { "const": false },
    "sent_output_writes": { "const": false },
    "sent_configuration_writes": { "const": false },
    "sent_firmware_or_dfu_commands": { "const": false },
    "high_torque_enabled": { "const": false },
    "mode_enable_candidates_sendable": { "const": false },
    "planned_next_output_allowed": { "const": false },
    "unknown_safety_or_mode_state_blocks_authority": { "const": true },
    "exact_next_blocker": { "type": "string" },
    "next_allowed_action": { "type": "string" },
    "blocked_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
